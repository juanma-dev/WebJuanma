# ============================================================
# Compose-level variables — copied to .env next to docker-compose.yml.
# These are NOT secrets that go inside containers. Backend secrets
# (SMTP_USER, SMTP_PASS, ...) live in BACKEND_ENV_FILE below.
#
# Setup on a fresh server:
#   cp compose.env.example .env
#   chmod 600 .env
#   ${EDITOR:-vi} .env
# ============================================================

# Container registry / image owner.
# Use your GitHub username/org for ghcr.io.
GHCR_OWNER=your-github-user
TAG=latest

# Optional: override the full image references (handy for local builds).
# BACKEND_IMAGE=webjuanma-api:dev
# FRONTEND_IMAGE=webjuanma-web:dev

# Public origin used by CORS. The string must match your Cloudflare hostname.
PUBLIC_ORIGIN=https://webjuanma.com

# Where SQLite stores its db on the host. The bind mount in
# docker-compose.yml points the container's /app/data here.
# IMPORTANT: chown to UID 1000 (the `webjuanma` user inside the container):
#   sudo mkdir -p /var/lib/webjuanma/data
#   sudo chown -R 1000:1000 /var/lib/webjuanma/data
DATA_DIR=/var/lib/webjuanma/data

# Path to the backend's runtime env file. NEVER commit this file.
# Required keys inside it: SMTP_HOST, SMTP_PORT, SMTP_USER, SMTP_PASS,
# CONTACT_TO_EMAIL.
# Example bootstrap:
#   sudo install -m 700 -d /etc/webjuanma
#   sudo install -m 600 backend/.env.example /etc/webjuanma/backend.env
#   sudo ${EDITOR:-vi} /etc/webjuanma/backend.env
BACKEND_ENV_FILE=/etc/webjuanma/backend.env

# Cloudflare Tunnel token. Create the tunnel in
# https://one.dash.cloudflare.com/  → Networks → Tunnels → Create.
# Pick "Docker" as the connector and copy the long token at the end of
# the suggested `cloudflared ... --token <TOKEN>` command.
CLOUDFLARED_TOKEN=
